}));

// Gradient bar
var makeGradientBar = function(palette, min, max) {
  var bar = ui.Thumbnail({
    image: ee.Image.pixelLonLat().select('longitude'),
    params: {
      bbox: [0, 0, 1, 0.1],
      dimensions: '200x20',
      format: 'png',
      min: 0, max: 1,
      palette: palette
    },
    style: {stretch: 'horizontal', margin: '4px 0', maxHeight: '24px'}
  });
  var labels = ui.Panel({
    widgets: [
      ui.Label(min + '°C', {margin: '0', fontSize: '11px'}),
      ui.Label(max + '°C', {margin: '0 0 0 150px', fontSize: '11px'})
    ],
    layout: ui.Panel.Layout.flow('horizontal')
  });
  return ui.Panel([bar, labels]);
};

legend.add(makeGradientBar(lstDayVis.palette, '-5', '50'));

legend.add(ui.Label({
  value: '🔴 Hot Spots > 40°C  |  🔵 Cold Spots < 0°C',
  style: {fontSize: '11px', margin: '6px 0 0 0', color: '#555'}
}));

legend.add(ui.Label({
  value: '⚠️ Anomaly: Blue = Cooler | Red = Warmer than baseline',
  style: {fontSize: '11px', margin: '4px 0 0 0', color: '#555'}
}));

Map.add(legend);

